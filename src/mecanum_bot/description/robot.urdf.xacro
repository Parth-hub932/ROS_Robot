<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mecanum_bot">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.25 0.15 0.05"/>
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="0.0485" length="0.03"/> </geometry>
        <material name="black"><color rgba="0 0 0 1"/></material>
      </visual>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} 0" rpy="-1.57 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="fl" x="0.10" y="0.12"/>
  <xacro:wheel name="fr" x="0.10" y="-0.12"/>
  <xacro:wheel name="rl" x="-0.10" y="0.12"/>
  <xacro:wheel name="rr" x="-0.10" y="-0.12"/>

  <ros2_control name="MecanumTopicBased" type="system">
    
    <hardware>
      <plugin>mecanum_hardware/MecanumSystem</plugin>
      
      <param name="port">/dev/ttyACM0</param>
      <param name="baudrate">115200</param>
    </hardware>

    <joint name="fl_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="fr_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rl_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rr_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

</robot>